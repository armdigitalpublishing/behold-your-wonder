---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Women's Mental Health & Hormonal Care">

<!-- HERO -->
<section class="hero">
  <div class="blob-field" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
  <div class="hero-content fade-up">
    <span class="eyebrow eyebrow-dark">Women's mental health · Hormonal care · Online clinic</span>
    <h1>Your hormones affect everything.<br>Your care should reflect that.</h1>
    <p class="hero-sub">Behold Your Wonder is an online mental health clinic for women navigating PMDD, perimenopause, postpartum, fertility, and the emotional weight of hormonal health.</p>
    <div class="btn-row">
      <a href="/contact" class="btn-primary">Talk to a specialist</a>

    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust" role="list">
  <span class="trust-item" role="listitem">HIPAA compliant</span>
  <div class="trust-sep"></div>
  <span class="trust-item" role="listitem">Licensed clinicians</span>
  <div class="trust-sep"></div>
  <span class="trust-item" role="listitem">100% telehealth</span>
  <div class="trust-sep"></div>
  <span class="trust-item" role="listitem">Multiple states served</span>
  <div class="trust-sep"></div>
  <span class="trust-item" role="listitem">Evidence-based modalities</span>
</div>

<!-- VALUE PROPS -->
<section class="vp">
  <div class="container">
    <div class="vp-head fade-up">
      <span class="eyebrow eyebrow-light">Mind. Body. Support.</span>
      <h2>Your body and mind aren't separate.<br>Your care shouldn't be either.</h2>
    </div>
    <div class="card-grid">
      <div class="vp-card fade-up">
        <div class="vp-icon" aria-hidden="true">✦</div>
        <p class="vp-title">Therapy that knows your body</p>
        <p class="vp-desc">1:1 sessions, group therapy, and async support from clinicians trained in hormonal mental health. You won't have to explain why your cycle affects your mood.</p>
        <a href="/services" class="vp-link">See how it works →</a>
      </div>
      <div class="vp-card fade-up">
        <div class="vp-icon" aria-hidden="true">✦</div>
        <p class="vp-title">A specialist network that talks to your therapist</p>
        <p class="vp-desc">Warm referrals to OBGYNs, PMHNPs, doulas, fertility coaches, and more. Vetted practitioners who receive your full context before you arrive.</p>
        <a href="/services" class="vp-link">See how it works →</a>
      </div>
      <div class="vp-card fade-up">
        <div class="vp-icon" aria-hidden="true">✦</div>
        <p class="vp-title">One front door to your care</p>
        <p class="vp-desc">Your Mental Health Coordinator handles scheduling, referrals, and continuity. You never have to figure out who to contact or how to navigate your own care.</p>
        <a href="/services" class="vp-link">See how it works →</a>
      </div>
    </div>
  </div>
</section>

<!-- WHO THIS IS FOR -->
<section class="who">
  <div class="container">
    <div class="who-head fade-up">
      <span class="eyebrow eyebrow-dark">Who this is for</span>
      <h2>If you've ever been told it's just stress —<br>this was built for you.</h2>
    </div>
    <div class="condition-grid">
      <div class="condition-card fade-up"><div class="condition-dot"></div><div><p class="condition-name">PMDD</p><p class="condition-desc">Premenstrual dysphoric disorder</p></div></div>
      <div class="condition-card fade-up"><div class="condition-dot"></div><div><p class="condition-name">Perimenopause</p><p class="condition-desc">Hormonal transition & mood shifts</p></div></div>
      <div class="condition-card fade-up"><div class="condition-dot"></div><div><p class="condition-name">Postpartum</p><p class="condition-desc">Anxiety, depression & adjustment</p></div></div>
      <div class="condition-card fade-up"><div class="condition-dot"></div><div><p class="condition-name">Fertility grief</p><p class="condition-desc">Loss, IVF, and the in-between</p></div></div>
      <div class="condition-card fade-up"><div class="condition-dot"></div><div><p class="condition-name">PCOS</p><p class="condition-desc">Hormonal & emotional complexity</p></div></div>
      <div class="condition-card fade-up"><div class="condition-dot"></div><div><p class="condition-name">Thyroid disorders</p><p class="condition-desc">Mood, energy & mental health</p></div></div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how">
  <div class="container">
    <div class="how-head fade-up">
      <span class="eyebrow eyebrow-light">How it works</span>
      <h2>From first contact to ongoing care</h2>
    </div>
    <div class="steps">
      <div class="step fade-up">
        <div class="step-num" aria-hidden="true">01</div>
        <p class="step-title">Book a 25 minute consultation</p>
        <p class="step-desc">A 25-minute video call with a licensed therapist to understand your needs, concerns, and goals.</p>
      </div>
      <div class="step fade-up">
        <div class="step-num" aria-hidden="true">02</div>
        <p class="step-title">Get matched</p>
        <p class="step-desc">We pair you with a licensed clinician who has direct experience with your specific hormonal health concerns.</p>
      </div>
      <div class="step fade-up">
        <div class="step-num" aria-hidden="true">03</div>
        <p class="step-title">Begin care</p>
        <p class="step-desc">Start therapy, access async support between sessions, and connect to our specialist network — all coordinated in one place.</p>
      </div>
    </div>
  </div>
</section>

<!-- CMBT -->
<section class="cmbt">
  <div class="container">
    <div class="cmbt-card fade-up">
      <span class="cmbt-badge">Our clinical modality</span>
      <h2>Behold Your Wonder Center<br>Core Messaging Based Therapy</h2>
      <p class="cmbt-desc">CMBT is our proprietary integrative therapy — drawing on CBT, psychodynamic, EFT, and humanistic approaches — designed to help clients uncover, explore, and reframe the internalized messages shaping their emotional and relational lives.</p>
      <a href="/cmbt" class="btn-outline-dark">See how it works</a>
    </div>
  </div>
</section>

<!-- CREDENTIALS -->
<section class="creds">
  <div class="container">
    <div class="creds-head fade-up">
      <span class="eyebrow eyebrow-light">Clinical standards</span>
      <h2>Care you can trust.<br>Standards that show it.</h2>
      <p class="creds-sub">Every clinician at Behold Your Wonder meets rigorous standards — not just for licensure, but for specialized expertise in women's hormonal mental health.</p>
    </div>
    <div class="cred-grid">
      <div class="cred-card fade-up">
        <div class="cred-icon" aria-hidden="true">✦</div>
        <div><p class="cred-title">Fully licensed clinicians</p><p class="cred-desc">All therapists hold active state licensure — LMFT, LPC, or LCSW — and are individually vetted before joining our clinical team.</p></div>
      </div>
      <div class="cred-card fade-up">
        <div class="cred-icon" aria-hidden="true">✦</div>
        <div><p class="cred-title">Hormonal health specialization</p><p class="cred-desc">We only work with clinicians who have direct experience treating PMDD, perinatal mood disorders, perimenopause, and hormonal mental health.</p></div>
      </div>
      <div class="cred-card fade-up">
        <div class="cred-icon" aria-hidden="true">✦</div>
        <div><p class="cred-title">HIPAA compliant telehealth</p><p class="cred-desc">All sessions are delivered via secure, encrypted telehealth platforms that meet or exceed HIPAA standards for protected health information.</p></div>
      </div>
      <div class="cred-card fade-up">
        <div class="cred-icon" aria-hidden="true">✦</div>
        <div><p class="cred-title">PMHNP medication support</p><p class="cred-desc">When medication evaluation is appropriate, we connect you to our network of Psychiatric Mental Health Nurse Practitioners — no separate referral needed.</p></div>
      </div>
    </div>
    <div class="license-strip fade-up">
      <span class="license-label">Clinician credentials include</span>
      <span class="license-pill">LMFT</span>
      <span class="license-pill">LPC</span>
      <span class="license-pill">LCSW</span>
      <span class="license-pill">PMHNP</span>
      <span class="license-pill">Evidence-based</span>
      <span class="license-pill">Telehealth</span>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="test">
  <div class="container">
    <div class="test-head fade-up">
      <span class="eyebrow eyebrow-dark">Client experiences</span>
      <h2>Women who found their way here</h2>
    </div>
    <div class="test-grid">
      <div class="test-card fade-up">
        <div class="test-stars" aria-label="5 stars">★★★★★</div>
        <p class="test-quote">"For the first time, my therapist understood that my cycle and my mental health were the same conversation."</p>
        <p class="test-author">— Client</p><p class="test-condition">PMDD</p>
      </div>
      <div class="test-card fade-up">
        <div class="test-stars" aria-label="5 stars">★★★★★</div>
        <p class="test-quote">"I didn't have to explain myself from scratch. They already understood what perimenopause does to your mind."</p>
        <p class="test-author">— Client</p><p class="test-condition">Perimenopause</p>
      </div>
      <div class="test-card fade-up">
        <div class="test-stars" aria-label="5 stars">★★★★★</div>
        <p class="test-quote">"The coordinator handled everything. I just had to show up. That alone changed everything for me."</p>
        <p class="test-author">— Client</p><p class="test-condition">Postpartum</p>
      </div>
    </div>
  </div>
</section>

<!-- ARTICLES -->
<section class="articles">
  <div class="container">
    <div class="articles-head fade-up">
      <span class="eyebrow eyebrow-light">From our journal</span>
      <h2>Understand what's happening in your body</h2>
      <p class="articles-sub">Clinical insights written for real women — not search engines.</p>
    </div>
    <div class="articles-grid">
      <article class="art-card fade-up">
        <div class="art-img" aria-hidden="true"></div>
        <div class="art-body">
          <span class="art-cat cat-hormonal">Hormonal health</span>
          <p class="art-title">What PMDD actually does to your brain — and why it's not in your head</p>
          <p class="art-excerpt">Understanding the luteal phase, estrogen withdrawal, and why your mood changes aren't a character flaw.</p>
          <div class="art-meta">6 min read</div>
        </div>
      </article>
      <article class="art-card fade-up">
        <div class="art-img" aria-hidden="true"></div>
        <div class="art-body">
          <span class="art-cat cat-mental">Mental wellness</span>
          <p class="art-title">The emotional weight of perimenopause nobody talks about</p>
          <p class="art-excerpt">Anxiety, rage, and grief that arrives before menopause — what it is and what actually helps.</p>
          <div class="art-meta">8 min read</div>
        </div>
      </article>
      <article class="art-card fade-up">
        <div class="art-img" aria-hidden="true"></div>
        <div class="art-body">
          <span class="art-cat cat-clinical">Clinical insights</span>
          <p class="art-title">Why fragmented care fails women with hormonal conditions</p>
          <p class="art-excerpt">When your OBGYN and therapist never speak to each other, you pay the price. Here's a better model.</p>
          <div class="art-meta">5 min read</div>
        </div>
      </article>
    </div>
    <div class="articles-cta fade-up">
      <a href="/resources" class="btn-ghost">View all articles</a>
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="nl">
  <div class="nl-blob-1" aria-hidden="true"></div>
  <div class="nl-blob-2" aria-hidden="true"></div>
  <div class="nl-content fade-up">
    <span class="eyebrow eyebrow-dark">A community that gets it. In your inbox.</span>
    <h2>The information you wished your doctor gave you.</h2>
    <p class="nl-sub">Curated insights from leading professionals in women's mental health and hormonal care — delivered weekly.</p>
<form class="nl-form" id="nl-form" action="https://formspree.io/f/mdavaqnb" method="POST">      <input class="nl-input" type="text" name="name" placeholder="Your name" autocomplete="name" required>
      <input class="nl-input" type="email" name="email" placeholder="Your email" autocomplete="email" required>
      <button class="nl-btn" type="submit" id="nl-btn">Sign up privately</button>
    </form>
    <p class="nl-privacy">We never share your information. Unsubscribe any time.</p>
  </div>
</section>

</Layout>

<style>
/* HERO */
.hero{background:var(--cream);position:relative;overflow:hidden;padding:var(--pad) 0;text-align:center}
.blob-field{position:absolute;inset:0;pointer-events:none;z-index:0}
.blob{position:absolute;opacity:0.2}
.blob-1{width:clamp(280px,45vw,580px);height:clamp(160px,26vw,340px);background:#D9A89A;top:-40px;left:-80px;border-radius:65% 35% 50% 50% / 55% 45% 60% 40%;animation:blob1 14s ease-in-out infinite}
.blob-2{width:clamp(240px,38vw,500px);height:clamp(140px,22vw,300px);background:#C8B4A8;bottom:-40px;right:-60px;border-radius:50% 60% 40% 55% / 60% 40% 55% 45%;animation:blob2 18s ease-in-out infinite}
.blob-3{width:clamp(180px,28vw,360px);height:clamp(110px,17vw,220px);background:#D4A090;top:60px;right:clamp(20px,10vw,120px);border-radius:55% 45% 62% 38% / 48% 58% 42% 52%;animation:blob3 11s ease-in-out infinite}
@keyframes blob1{0%,100%{transform:translate(0,0) scale(1) rotate(0deg)}33%{transform:translate(18px,-12px) scale(1.03) rotate(1.5deg)}66%{transform:translate(-10px,16px) scale(0.97) rotate(-1deg)}}
@keyframes blob2{0%,100%{transform:translate(0,0) scale(1) rotate(0deg)}40%{transform:translate(-20px,14px) scale(1.04) rotate(-2deg)}75%{transform:translate(12px,-8px) scale(0.98) rotate(1deg)}}
@keyframes blob3{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(10px,12px) scale(0.96)}}
.hero-content{position:relative;z-index:1;max-width:680px;margin:0 auto;padding:0 clamp(20px,5vw,48px)}
.hero h1{color:var(--green-dark);margin-bottom:20px}
.hero-sub{font-size:clamp(14px,1.8vw,16px);color:#5A4A40;line-height:1.75;margin-bottom:38px}
.btn-outline{background:transparent;color:var(--green-dark);font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:14px 32px;border-radius:var(--radius-pill);border:1.5px solid var(--green-dark);display:inline-block;transition:background 0.2s,color 0.2s}
.btn-outline:hover{background:var(--green-dark);color:#fff}

/* TRUST BAR */
.trust{background:var(--green-dark);padding:16px clamp(20px,5vw,48px);display:flex;align-items:center;justify-content:center;gap:clamp(16px,3vw,36px);flex-wrap:wrap}
.trust-item{font-size:clamp(10px,1.2vw,12px);letter-spacing:0.06em;color:rgba(255,255,255,0.6)}
.trust-sep{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,0.2)}

/* VALUE PROPS */
.vp{background:var(--green-mid);padding:var(--pad) 0}
.vp-head{text-align:center;margin-bottom:clamp(36px,5vw,56px)}
.vp-head h2{color:#fff}
.card-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap)}
.vp-card{background:rgba(255,255,255,0.055);border:0.5px solid rgba(255,255,255,0.11);border-radius:var(--radius-lg);padding:clamp(22px,3vw,34px);transition:background 0.25s}
.vp-card:hover{background:rgba(255,255,255,0.08)}
.vp-icon{width:46px;height:46px;background:var(--rose-light);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;margin-bottom:18px;color:var(--rose);font-size:18px}
.vp-title{font-size:clamp(13px,1.5vw,15px);font-weight:500;color:#fff;margin-bottom:10px;line-height:1.4}
.vp-desc{font-size:clamp(12px,1.3vw,13px);color:rgba(255,255,255,0.52);line-height:1.75;margin-bottom:18px}
.vp-link{font-size:12px;color:var(--rose);display:flex;align-items:center;gap:6px;transition:gap 0.2s}
.vp-link:hover{gap:10px}

/* WHO THIS IS FOR */
.who{background:var(--cream);padding:var(--pad) 0}
.who-head{text-align:center;margin-bottom:clamp(36px,5vw,52px)}
.who-head h2{color:var(--green-dark)}
.condition-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap)}
.condition-card{background:#fff;border:0.5px solid rgba(30,45,30,0.1);border-radius:var(--radius-md);padding:20px 22px;display:flex;align-items:flex-start;gap:14px;transition:border-color 0.2s}
.condition-card:hover{border-color:var(--rose)}
.condition-dot{width:8px;height:8px;border-radius:50%;background:var(--rose);flex-shrink:0;margin-top:5px}
.condition-name{font-size:clamp(13px,1.5vw,14px);font-weight:500;color:var(--green-dark);margin-bottom:3px}
.condition-desc{font-size:clamp(11px,1.2vw,12px);color:#7A6A60;line-height:1.5}

/* HOW IT WORKS */
.how{background:var(--green-dark);padding:var(--pad) 0}
.how-head{text-align:center;margin-bottom:clamp(40px,5vw,64px)}
.how-head h2{color:#fff}
.steps{display:grid;grid-template-columns:repeat(3,1fr)}
.step{text-align:center;padding:0 clamp(20px,3vw,48px);position:relative}
.step:not(:last-child)::after{content:'';position:absolute;right:0;top:28px;width:1px;height:48px;background:rgba(255,255,255,0.12)}
.step-num{font-family:var(--serif);font-size:clamp(48px,6vw,72px);font-weight:400;color:rgba(255,255,255,0.07);line-height:1;margin-bottom:10px}
.step-title{font-size:clamp(13px,1.5vw,15px);font-weight:500;color:#fff;margin-bottom:10px}
.step-desc{font-size:clamp(12px,1.3vw,13px);color:rgba(255,255,255,0.48);line-height:1.75}

/* CMBT */
.cmbt{background:var(--cream);padding:var(--pad) 0}
.cmbt-card{max-width:740px;margin:0 auto;background:#fff;border:1px solid rgba(196,145,122,0.3);border-radius:var(--radius-lg);padding:clamp(36px,5vw,64px) clamp(28px,5vw,60px);text-align:center}
.cmbt-badge{display:inline-block;font-size:10px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--rose);background:var(--rose-light);padding:6px 16px;border-radius:var(--radius-pill);margin-bottom:26px}
.cmbt-card h2{color:var(--green-dark);margin-bottom:16px;font-size:clamp(20px,3vw,34px)}
.cmbt-desc{font-size:clamp(13px,1.5vw,15px);color:#5A4A40;line-height:1.85;margin-bottom:30px}
.btn-outline-dark{border:1.5px solid var(--green-dark);color:var(--green-dark);font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:14px 32px;border-radius:var(--radius-pill);display:inline-block;transition:background 0.2s,color 0.2s}
.btn-outline-dark:hover{background:var(--green-dark);color:#fff}

/* CREDENTIALS */
.creds{background:var(--green-mid);padding:var(--pad) 0}
.creds-head{text-align:center;margin-bottom:clamp(36px,5vw,56px)}
.creds-head h2{color:#fff}
.creds-sub{font-size:clamp(13px,1.5vw,14px);color:rgba(255,255,255,0.48);line-height:1.75;max-width:480px;margin:14px auto 0}
.cred-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--gap);margin-bottom:44px}
.cred-card{background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.1);border-radius:var(--radius-lg);padding:clamp(22px,3vw,32px);display:flex;align-items:flex-start;gap:18px;transition:background 0.25s}
.cred-card:hover{background:rgba(255,255,255,0.08)}
.cred-icon{width:46px;height:46px;background:var(--rose-light);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--rose);font-size:18px}
.cred-title{font-size:clamp(13px,1.5vw,15px);font-weight:500;color:#fff;margin-bottom:8px}
.cred-desc{font-size:clamp(12px,1.3vw,13px);color:rgba(255,255,255,0.5);line-height:1.75}
.license-strip{border-top:0.5px solid rgba(255,255,255,0.1);padding-top:32px;display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap}
.license-label{font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:0.06em;text-transform:uppercase;margin-right:6px}
.license-pill{background:rgba(255,255,255,0.07);border:0.5px solid rgba(255,255,255,0.12);border-radius:var(--radius-pill);padding:6px 16px;font-size:12px;color:rgba(255,255,255,0.6);font-weight:500}

/* TESTIMONIALS */
.test{background:var(--cream);padding:var(--pad) 0}
.test-head{text-align:center;margin-bottom:clamp(36px,5vw,52px)}
.test-head h2{color:var(--green-dark)}
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap)}
.test-card{background:#fff;border:0.5px solid rgba(30,45,30,0.1);border-radius:var(--radius-lg);padding:clamp(22px,3vw,30px)}
.test-stars{color:var(--rose);font-size:14px;margin-bottom:14px;letter-spacing:2px}
.test-quote{font-family:var(--serif);font-size:clamp(16px,2vw,19px);font-style:italic;color:var(--green-dark);line-height:1.6;margin-bottom:18px}
.test-author{font-size:12px;color:#7A6A60;font-weight:500}
.test-condition{font-size:11px;color:var(--rose);margin-top:3px}

/* ARTICLES */
.articles{background:var(--green-dark);padding:var(--pad) 0}
.articles-head{text-align:center;margin-bottom:clamp(36px,5vw,52px)}
.articles-head h2{color:#fff}
.articles-sub{font-size:clamp(13px,1.5vw,14px);color:rgba(255,255,255,0.45);margin-top:10px}
.articles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap)}
.art-card{background:rgba(255,255,255,0.04);border:0.5px solid rgba(255,255,255,0.09);border-radius:var(--radius-lg);overflow:hidden;transition:background 0.25s;cursor:pointer}
.art-card:hover{background:rgba(255,255,255,0.07)}
.art-img{height:120px;background:rgba(255,255,255,0.05);border-bottom:0.5px solid rgba(255,255,255,0.07)}
.art-body{padding:20px}
.art-cat{display:inline-block;font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:4px 10px;border-radius:4px;margin-bottom:12px}
.cat-hormonal{background:rgba(196,145,122,0.18);color:var(--rose)}
.cat-mental{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.55)}
.cat-clinical{background:rgba(42,56,40,0.7);color:rgba(255,255,255,0.55);border:0.5px solid rgba(255,255,255,0.1)}
.art-title{font-family:var(--serif);font-size:clamp(16px,2vw,19px);font-weight:500;color:#fff;line-height:1.4;margin-bottom:10px}
.art-excerpt{font-size:clamp(11px,1.2vw,12px);color:rgba(255,255,255,0.42);line-height:1.7;margin-bottom:12px}
.art-meta{font-size:11px;color:rgba(255,255,255,0.28)}
.articles-cta{text-align:center;margin-top:40px}
.btn-ghost{display:inline-block;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:13px 32px;border-radius:var(--radius-pill);transition:border-color 0.2s,color 0.2s}
.btn-ghost:hover{border-color:rgba(255,255,255,0.5);color:#fff}

/* NEWSLETTER */
.nl{background:var(--cream);padding:var(--pad) 0;text-align:center;position:relative;overflow:hidden}
.nl-blob-1{position:absolute;width:clamp(220px,35vw,440px);height:clamp(130px,20vw,260px);background:#D9A89A;opacity:0.17;border-radius:65% 35% 50% 50% / 55% 45% 60% 40%;top:-50px;left:-80px;animation:blob1 16s ease-in-out infinite;pointer-events:none}
.nl-blob-2{position:absolute;width:clamp(200px,30vw,380px);height:clamp(120px,18vw,220px);background:#C8B4A8;opacity:0.14;border-radius:50% 60% 40% 55% / 60% 40% 55% 45%;bottom:-40px;right:-60px;animation:blob2 20s ease-in-out infinite;pointer-events:none}
.nl-content{position:relative;z-index:1;max-width:520px;margin:0 auto;padding:0 clamp(20px,5vw,48px)}
.nl-content h2{color:var(--green-dark);margin-bottom:14px}
.nl-sub{font-size:clamp(13px,1.5vw,15px);color:#5A4A40;line-height:1.75;margin-bottom:34px}
.nl-form{display:flex;flex-direction:column;align-items:center;gap:14px}
.nl-input{width:100%;max-width:380px;background:transparent;border:none;border-bottom:1px solid rgba(30,45,30,0.28);padding:12px 0;font-size:14px;font-family:var(--sans);color:var(--green-dark);text-align:center;outline:none;transition:border-color 0.2s}
.nl-input::placeholder{color:rgba(30,45,30,0.38)}
.nl-input:focus{border-color:var(--rose)}
.nl-btn{background:var(--rose);color:#fff;font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:14px 36px;border-radius:var(--radius-pill);border:none;cursor:pointer;margin-top:8px;font-family:var(--sans);transition:opacity 0.2s}
.nl-btn:hover{opacity:0.88}
.nl-privacy{font-size:11px;color:rgba(30,45,30,0.38);margin-top:14px}

/* RESPONSIVE */
@media(max-width:900px){
  .card-grid,.test-grid,.articles-grid,.condition-grid{grid-template-columns:repeat(2,1fr)}
  .cred-grid{grid-template-columns:1fr}
  .steps{grid-template-columns:1fr;gap:40px}
  .step:not(:last-child)::after{display:none}
}
@media(max-width:600px){
  .card-grid,.test-grid,.articles-grid,.condition-grid{grid-template-columns:1fr}
  .trust{gap:12px}
  .trust-sep{display:none}
  .btn-row{flex-direction:column;align-items:center}
  .btn-primary,.btn-outline{width:100%;max-width:280px;text-align:center}
}
</style>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));


</script>