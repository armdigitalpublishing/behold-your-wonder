---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => 
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);
---

<Layout title="Journal">
  <section class="journal-hero">
    <div class="container">
      <span class="eyebrow">From our journal</span>
      <h1>Articles written for real women — not search engines.</h1>
      <p class="hero-sub">Clinical insights on hormonal health, mental wellness, and the conditions your provider may have missed.</p>
    </div>
  </section>
  <section class="journal-grid">
    <div class="container">
      <div class="art-grid">
        {sorted.map((article) => (
          <a href={`/journal/${article.id}`} class="art-card">
            <div class="art-img">
              <p class="art-img-label">{article.data.category}</p>
            </div>
            <div class="art-body">
              <span class="art-cat">{article.data.category}</span>
              <p class="art-title">{article.data.title}</p>
              <p class="art-excerpt">{article.data.excerpt}</p>
              <div class="art-meta">{article.data.readTime} read</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .journal-hero { background: #1E2D1E; padding: 80px 0; text-align: center; }
  .journal-hero h1 { color: #F5EFE8; font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3.5rem); margin: 12px 0; }
  .hero-sub { color: #F5EFE8; opacity: 0.8; max-width: 600px; margin: 0 auto; font-size: 1.1rem; line-height: 1.6; }
  .eyebrow { font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: #C4917A; display: block; margin-bottom: 12px; }
  .journal-grid { background: #F5EFE8; padding: 80px 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .art-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px; }
  .art-card { background: white; border-radius: 12px; overflow: hidden; text-decoration: none; display: block; transition: transform 0.2s ease; }
  .art-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(30,45,30,0.12); }
  .art-img { height: 160px; background: #2A3828; display: flex; align-items: flex-end; padding: 16px; }
  .art-img-label { color: #F5EFE8; opacity: 0.7; font-size: 0.75rem; text-transform: uppercase; margin: 0; }
  .art-body { padding: 24px; }
  .art-cat { font-size: 0.7rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: #C4917A; }
  .art-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: #1E2D1E; margin: 8px 0; line-height: 1.4; }
  .art-excerpt { font-size: 0.9rem; color: #666; line-height: 1.6; margin-bottom: 16px; }
  .art-meta { font-size: 0.8rem; color: #999; }
</style>
