---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description, canonicalUrl, ogImage } = Astro.props;
const metaDescription = description || 'Behold Your Wonder — online women\'s mental health and hormonal care clinic. Specializing in PMDD, perimenopause, postpartum, and PCOS.';
const metaImage = ogImage || 'https://behold-your-wonder.vercel.app/og-image.jpg';
const canonical = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Behold Your Wonder</title>
  <meta name="description" content={metaDescription}>
  <link rel="canonical" href={canonical}>

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | Behold Your Wonder`}>
  <meta property="og:description" content={metaDescription}>
  <meta property="og:image" content={metaImage}>
  <meta property="og:url" content={canonical}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Behold Your Wonder">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={`${title} | Behold Your Wonder`}>
  <meta name="twitter:description" content={metaDescription}>
  <meta name="twitter:image" content={metaImage}>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
  <Nav />
  <slot />
  <Footer />
</body>
</html>