---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resources">

<section class="page-hero">
  <div class="container fade-up">
    <span class="eyebrow eyebrow-light">Knowledge & support</span>
    <h1>Understand what's happening<br>in your body.</h1>
    <p class="page-hero-sub">Clinical insights, answered questions, and plain-language explanations of the hormonal and mental health conditions we treat.</p>
  </div>
</section>

<section class="journal">
  <div class="container">
    <div class="section-head fade-up">
      <span class="eyebrow eyebrow-dark">From our journal</span>
      <h2>Articles written for real women —<br>not search engines.</h2>
    </div>
    <div class="art-grid">
      <a href="/journal/pmdd-brain" class="art-card fade-up">
        <div class="art-top hormonal"></div>
        <div class="art-body">
          <span class="art-cat cat-hormonal">Hormonal health</span>
          <p class="art-title">What PMDD actually does to your brain — and why it's not in your head</p>
          <p class="art-excerpt">Understanding the luteal phase, estrogen withdrawal, and why your mood changes aren't a character flaw.</p>
          <div class="art-meta">6 min read</div>
        </div>
      </a>
      <a href="/journal/perimenopause-emotional-weight" class="art-card fade-up">
        <div class="art-top mental"></div>
        <div class="art-body">
          <span class="art-cat cat-mental">Mental wellness</span>
          <p class="art-title">The emotional weight of perimenopause nobody talks about</p>
          <p class="art-excerpt">Anxiety, rage, and grief that arrives before menopause — what it is and what actually helps.</p>
          <div class="art-meta">8 min read</div>
        </div>
      </a>
      <a href="/journal/fragmented-care" class="art-card fade-up">
        <div class="art-top clinical"></div>
        <div class="art-body">
          <span class="art-cat cat-clinical">Clinical insights</span>
          <p class="art-title">Why fragmented care fails women with hormonal conditions</p>
          <p class="art-excerpt">When your OBGYN and therapist never speak to each other, you pay the price. Here's a better model.</p>
          <div class="art-meta">5 min read</div>
        </div>
      </a>
      <a href="/journal/postpartum-anxiety" class="art-card fade-up">
        <div class="art-top perinatal"></div>
        <div class="art-body">
          <span class="art-cat cat-perinatal">Perinatal</span>
          <p class="art-title">Postpartum anxiety is not the same as postpartum depression</p>
          <p class="art-excerpt">The racing thoughts, the hypervigilance, the dread — and why it often goes unrecognized.</p>
          <div class="art-meta">7 min read</div>
        </div>
      </a>
      <a href="/journal/pcos-mental-health" class="art-card fade-up">
        <div class="art-top hormonal"></div>
        <div class="art-body">
          <span class="art-cat cat-hormonal">Hormonal health</span>
          <p class="art-title">PCOS and mental health — the connection your provider may have missed</p>
          <p class="art-excerpt">The psychological toll of PCOS is real, measurable, and almost never addressed in clinical settings.</p>
          <div class="art-meta">9 min read</div>
        </div>
      </a>
      <a href="/journal/cmbt-explainer" class="art-card fade-up">
        <div class="art-top clinical"></div>
        <div class="art-body">
          <span class="art-cat cat-clinical">Clinical insights</span>
          <p class="art-title">What is Core Messaging Based Therapy and how does it work?</p>
          <p class="art-excerpt">An accessible introduction to CMBT — the integrative modality developed at Behold Your Wonder.</p>
          <div class="art-meta">6 min read</div>
        </div>
      </a>
    </div>
  </div>
</section>

<section class="faq">
  <div class="container">
    <div class="faq-head fade-up">
      <span class="eyebrow eyebrow-light">Frequently asked</span>
      <h2>Questions we hear most</h2>
    </div>
    <div class="faq-list fade-up">
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">Do you accept insurance?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">We are currently in network with Kaiser Northern California, Optum, Western Health Advantage, and Aetna. However, many clients use their out-of-network benefits to get reimbursed for a portion of session costs — we can provide a superbill to submit to your insurance provider. We recommend contacting your insurance company to ask about out-of-network mental health benefits before your first session.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">Which states do you serve?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">Telehealth 1:1 therapy services may only be provided in the state where you are physically located at the time of your session. We currently serve clients in California, Arizona, Nevada, and Colorado. All other services offered by our practice do not constitute therapy, are not mental health treatment, and are not restricted by state licensure requirements.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">How is this different from regular therapy?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">Most therapy treats mental health in isolation from the body. At Behold Your Wonder, our clinicians are specifically selected for their experience with hormonal mental health. You won't need to explain why your cycle affects your mood. We also offer coordination with a specialist network, async support between sessions, and Mental Health Coordinator services — creating a clinical experience that most practices simply don't offer.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">What is a Mental Health Coordinator?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">Your Mental Health Coordinator is your dedicated administrative guide throughout your time with us. They manage your scheduling, connect you to the right clinician, coordinate referrals to our specialist network, and ensure nothing falls through the cracks. Every client is assigned a coordinator at intake at no additional charge.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">What is async support and how does it work?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">Async support is direct messaging access to your licensed clinician between sessions. Your clinician responds within an agreed window — typically within 24 hours on business days. This is not a crisis line or a bot. It is your therapist, accessible in a format that fits your life.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">How do I get started?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">Begin with a 25-minute consultation with a licensed therapist for $65. This dedicated time allows us to discuss what brings you to therapy, answer your questions, explore your goals, and determine whether Behold Your Wonder is the right fit for your needs.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">Is everything confidential and HIPAA compliant?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">Yes. All services at Behold Your Wonder are delivered via HIPAA-compliant, encrypted telehealth platforms. Your information is protected under HIPAA and will never be shared without your written consent, except in situations required by law.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button"><span class="faq-q-text">What is CMBT and do I have to use it?</span><div class="faq-icon"><span>+</span></div></button>
        <div class="faq-a"><p class="faq-a-inner">Core Messaging Based Therapy (CMBT) is our proprietary integrative modality. Not all clients will use CMBT — your clinician will work with you to determine the most appropriate approach based on your needs and goals. CMBT is one tool in our clinical toolkit, not a requirement for all clients.</p></div>
      </div>
    </div>
  </div>
</section>

<section class="downloads">
  <div class="container">
    <div class="downloads-head fade-up">
      <span class="eyebrow eyebrow-light">Free resources</span>
      <h2>Tools to help you understand<br>your experience</h2>
    </div>
    <div class="downloads-grid">
      <div class="download-card fade-up">
        <div class="download-icon">↓</div>
        <p class="download-title">Could Hormonal Changes Be Affecting My Mental Health?</p>
        <p class="download-desc">A self-assessment and reflection checklist for perimenopause and menopause.</p>
        <a href="/Hormonal Changes.pdf" download class="download-btn">Download</a>
      </div>
      <div class="download-card fade-up">
        <div class="download-icon">↓</div>
        <p class="download-title">Preparing for Your Hormonal Health Appointment</p>
        <p class="download-desc">Questions to discuss with your healthcare provider to ensure your concerns are fully explored.</p>
        <a href="/Preparing Hormonal Health.pdf" download class="download-btn">Download</a>
      </div>
      <div class="download-card fade-up">
        <div class="download-icon">↓</div>
        <p class="download-title">Is It Stress, Hormones, or Both?</p>
        <p class="download-desc">A CMBT hormonal mental health resource to help you understand what may be contributing to how you feel.</p>
        <a href="/Stress visuals.pdf" download class="download-btn">Download</a>
      </div>
    </div>
  </div>
</section>

<section class="resources-cta">
  <div class="container fade-up">
    <span class="eyebrow eyebrow-light">Ready for more than information</span>
    <h2>Talk to someone who understands.</h2>
    <p>Knowledge is the first step. When you're ready to take the next one, we're here.</p>
    <div class="btn-row">
      <a href="/contact" class="btn-primary">Talk to a licensed therapist</a>
    </div>
  </div>
</section>

</Layout>

<style>
.page-hero{background:var(--ink);padding:clamp(64px,10vw,110px) 0;text-align:center}
.page-hero h1{color:#fff;margin-bottom:18px}
.page-hero-sub{font-size:clamp(14px,1.8vw,16px);color:rgba(255,255,255,0.6);line-height:1.75;max-width:560px;margin:0 auto}

.journal{background:var(--cream);padding:var(--pad) 0}
.section-head{text-align:center;margin-bottom:clamp(36px,5vw,52px)}
.section-head h2{color:var(--ink)}
.art-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap)}
.art-card{background:#fff;border:0.5px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;transition:border-color 0.2s,transform 0.2s;display:block;color:inherit}
.art-card:hover{border-color:var(--gold);transform:translateY(-3px)}
.art-top{height:4px}
.art-top.hormonal{background:var(--gold)}
.art-top.mental{background:var(--ink)}
.art-top.clinical{background:var(--green)}
.art-top.perinatal{background:var(--blush)}
.art-body{padding:22px}
.art-cat{display:inline-block;font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:4px 10px;border-radius:4px;margin-bottom:10px}
.cat-hormonal{background:rgba(245,184,0,0.12);color:var(--gold-dk)}
.cat-mental{background:rgba(30,30,30,0.06);color:var(--ink-soft)}
.cat-clinical{background:rgba(125,217,138,0.15);color:#2E7D5E}
.cat-perinatal{background:rgba(247,138,138,0.12);color:#C05050}
.art-title{font-family:var(--serif);font-size:clamp(16px,2vw,19px);color:var(--ink);line-height:1.35;margin-bottom:8px;font-weight:400}
.art-excerpt{font-size:clamp(11px,1.2vw,12px);color:var(--ink-soft);line-height:1.7;margin-bottom:12px}
.art-meta{font-size:11px;color:#AAA}

.faq{background:var(--ink);padding:var(--pad) 0}
.faq-head{text-align:center;margin-bottom:clamp(36px,5vw,52px)}
.faq-head h2{color:#fff}
.faq-list{display:flex;flex-direction:column;max-width:800px;margin:0 auto}
.faq-item{border-bottom:0.5px solid rgba(255,255,255,0.08)}
.faq-q{width:100%;background:none;border:none;text-align:left;padding:22px 0;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:20px}
.faq-q-text{font-size:clamp(14px,1.6vw,16px);font-weight:500;color:#fff;line-height:1.4}
.faq-icon{width:22px;height:22px;border:1px solid rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform 0.3s,background 0.2s;color:rgba(255,255,255,0.7);font-size:15px}
.faq-item.open .faq-icon{transform:rotate(45deg);background:var(--gold);border-color:var(--gold);color:var(--ink)}
.faq-a{max-height:0;overflow:hidden;transition:max-height 0.4s ease}
.faq-a-inner{font-size:clamp(13px,1.5vw,14px);color:rgba(255,255,255,0.52);line-height:1.8;padding-bottom:22px}

.downloads{background:var(--ink);padding:var(--pad) 0}
.downloads-head{text-align:center;margin-bottom:clamp(36px,5vw,52px)}
.downloads-head h2{color:#fff}
.downloads-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--gap)}
.download-card{background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.1);border-radius:var(--radius-lg);padding:clamp(24px,3vw,32px);display:flex;flex-direction:column;gap:12px}
.download-icon{width:40px;height:40px;border-radius:50%;background:rgba(245,184,0,0.15);color:var(--gold);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:500}
.download-title{font-size:clamp(14px,1.6vw,16px);font-weight:500;color:#fff;line-height:1.4}
.download-desc{font-size:clamp(12px,1.3vw,13px);color:rgba(255,255,255,0.5);line-height:1.7;flex:1}
.download-btn{display:inline-block;background:var(--gold);color:var(--ink);font-size:12px;font-weight:600;padding:10px 20px;border-radius:var(--radius-pill);text-align:center;transition:opacity 0.2s;margin-top:auto}
.download-btn:hover{opacity:0.88}

.resources-cta{background:var(--gold);padding:var(--pad) 0;text-align:center}
.resources-cta h2{color:var(--ink);margin-bottom:14px}
.resources-cta p{font-size:clamp(13px,1.5vw,15px);color:rgba(30,30,30,0.65);max-width:480px;margin:0 auto 32px;line-height:1.75}

@media(max-width:900px){.art-grid{grid-template-columns:repeat(2,1fr)}.downloads-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.art-grid,.downloads-grid{grid-template-columns:1fr}}
</style>

<script>
const observer = new IntersectionObserver(e => {
  e.forEach(t => { if(t.isIntersecting){ t.target.classList.add('visible'); observer.unobserve(t.target); }});
}, {threshold:0.1, rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

function toggleFaq(btn) {
  const item = btn.parentElement;
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i => {
    i.classList.remove('open');
    i.querySelector('.faq-a').style.maxHeight = '0';
  });
  if (!isOpen) {
    item.classList.add('open');
    item.querySelector('.faq-a').style.maxHeight = item.querySelector('.faq-a-inner').scrollHeight + 'px';
  }
}
document.querySelectorAll('.faq-q').forEach(btn => btn.addEventListener('click', () => toggleFaq(btn)));
</script>
