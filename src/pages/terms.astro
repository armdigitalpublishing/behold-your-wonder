<style>
  .legal-hero { background: #1E2D1E; padding: 80px 0; text-align: center; }
  .legal-body { background: #F5EFE8; padding: 80px 0; }
  .legal-content { max-width: 720px; margin: 0 auto; font-size: 1.05rem; line-height: 1.8; color: #1E2D1E; }
  :global(.legal-content h2) { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: #1E2D1E; margin: 48px 0 16px; }
  :global(.legal-content p) { margin-bottom: 20px; }
  :global(.legal-content ul) { padding-left: 24px; margin-bottom: 20px; }
  :global(.legal-content li) { margin-bottom: 8px; }
  :global(.legal-content a) { color: #C4917A; text-decoration: underline; }
