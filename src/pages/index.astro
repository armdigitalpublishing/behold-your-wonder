<script>
// Who it's for — dual mode: desktop panel swap / mobile accordion
const whoList = document.getElementById('who-list');
if (whoList) {
  const isMobile = () => window.innerWidth <= 768;

  whoList.addEventListener('click', e => {
    const item = e.target.closest('.who-item');
    if (!item) return;

    if (isMobile()) {
      // ACCORDION MODE — toggle open/closed, allow multiple closed
      const isOpen = item.classList.contains('open');
      // Close all
      whoList.querySelectorAll('.who-item').forEach(i => i.classList.remove('open'));
      // Open tapped one unless it was already open
      if (!isOpen) item.classList.add('open');
    } else {
      // DESKTOP MODE — swap active + update right panel
      whoList.querySelectorAll('.who-item').forEach(i => i.classList.remove('active'));
      item.classList.add('active');
      document.querySelectorAll('.who-panel').forEach(p => p.classList.remove('active'));
      const panel = document.getElementById('panel-' + item.dataset.target);
      if (panel) panel.classList.add('active');
    }
  });
}

// Fade-up on scroll
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }});
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>
