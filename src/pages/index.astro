---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Women's Mental Health & Hormonal Care">

<!-- ── HERO ─────────────────────────────────────── -->
<section class="hero">
  <!-- Poster image loads instantly while video loads -->
  <div class="hero-poster"></div>

  <!-- Looping video — swap src for your own file -->
  <div class="hero-video-wrap">
    <video autoplay muted loop playsinline
      poster="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=1600&q=80">
      <source src="https://www.pexels.com/video/3576378/download/?fps=25&h=1080&w=1920" type="video/mp4"/>
    </video>
  </div>

  <!-- Gradient overlay -->
  <div class="hero-overlay"></div>

  <!-- Content -->
  <div class="container">
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="hero-dot"></span>
        Online clinic · Multiple states · 100% telehealth
      </div>
      <h1>
        Your hormones<br>
        affect <span class="hl">everything.</span><br>
        Your care should<br>
        <em>reflect that.</em>
      </h1>
      <p class="hero-sub">
        Behold Your Wonder is a women's mental health clinic specializing in PMDD,
        perimenopause, postpartum, and the emotional weight of hormonal health.
      </p>
      <div class="hero-actions">
        <a href="https://beholdyourwonder.clientsecure.me" class="btn-gold" target="_blank" rel="noopener">Connect to a specialist</a>
        <a href="/services" class="btn-ghost-white">See how it works</a>
      </div>
      <div class="trust-row">
        <span class="trust-chip">✓ HIPAA compliant</span>
        <span class="trust-chip">✓ Licensed clinicians</span>
        <span class="trust-chip">✓ Multiple states</span>
        <span class="trust-chip">✓ Evidence-based</span>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="hero-scroll-line"></div>
    <span>scroll</span>
  </div>
</section>

<!-- ── STATEMENT ──────────────────────────────────── -->
<section class="statement">
  <div class="container">
    <p class="statement-text">
      Behold Your Wonder is a mental health clinic for women who've been dismissed —
      built around the truth that your <span class="hl-ink">body and mind</span>
      are not separate, and your care <span class="hl-green">shouldn't be either.</span>
    </p>
    <div class="compliance-row">
      <div class="compliance-badge">
        <div class="compliance-icon">🛡️</div>
        HIPAA Compliant
      </div>
      <div class="compliance-badge">
        <div class="compliance-icon">📋</div>
        Licensed Clinicians Only
      </div>
      <div class="compliance-badge">
        <div class="compliance-icon">🔬</div>
        Evidence-Based Modalities
      </div>
    </div>
  </div>
</section>

<!-- ── WHO IT'S FOR ───────────────────────────────── -->
<section class="who">
  <div class="container">
    <div class="who-inner">
      <div class="who-left">
        <p class="eyebrow eyebrow-dark">Who this is for</p>
        <ul class="who-list" id="who-list">

          <li class="who-item active" data-target="pmdd">
            <div class="who-trigger">
              <span class="who-dot"></span>
              <span class="who-name">PMDD</span>
              <span class="who-arrow">→</span>
              <span class="who-chevron" aria-hidden="true"></span>
            </div>
            <div class="who-drawer">
              <p class="who-drawer-text">The luteal phase shouldn't feel like a different life. Our clinicians understand PMDD at a neurological level — not as moodiness, but as a disorder that deserves real clinical attention and a real treatment plan.</p>
              <a href="/services" class="who-drawer-link">Learn more →</a>
            </div>
          </li>

          <li class="who-item" data-target="perimenopause">
            <div class="who-trigger">
              <span class="who-dot"></span>
              <span class="who-name">Perimenopause</span>
              <span class="who-arrow">→</span>
              <span class="who-chevron" aria-hidden="true"></span>
            </div>
            <div class="who-drawer">
              <p class="who-drawer-text">The anxiety, rage, and grief that arrives before menopause is real — and undertreated. We work with women navigating hormonal transition with clinicians who understand what estrogen does to mood, cognition, and identity.</p>
              <a href="/services" class="who-drawer-link">Learn more →</a>
            </div>
          </li>

          <li class="who-item" data-target="postpartum">
            <div class="who-trigger">
              <span class="who-dot"></span>
              <span class="who-name">Postpartum</span>
              <span class="who-arrow">→</span>
              <span class="who-chevron" aria-hidden="true"></span>
            </div>
            <div class="who-drawer">
              <p class="who-drawer-text">Postpartum anxiety and depression are not character flaws. Our perinatal clinicians specialize in the emotional weight of the fourth trimester — and the months beyond it that no one talks about.</p>
              <a href="/services" class="who-drawer-link">Learn more →</a>
            </div>
          </li>

          <li class="who-item" data-target="fertility">
            <div class="who-trigger">
              <span class="who-dot"></span>
              <span class="who-name">Fertility grief</span>
              <span class="who-arrow">→</span>
              <span class="who-chevron" aria-hidden="true"></span>
            </div>
            <div class="who-drawer">
              <p class="who-drawer-text">Loss, IVF, miscarriage, and the in-between. Fertility grief is one of the most isolating emotional experiences a woman can face. We create space to process it — without minimizing it.</p>
              <a href="/services" class="who-drawer-link">Learn more →</a>
            </div>
          </li>

          <li class="who-item" data-target="pcos">
            <div class="who-trigger">
              <span class="who-dot"></span>
              <span class="who-name">PCOS</span>
              <span class="who-arrow">→</span>
              <span class="who-chevron" aria-hidden="true"></span>
            </div>
            <div class="who-drawer">
              <p class="who-drawer-text">PCOS affects hormones, mood, body image, and identity in ways that are rarely addressed in a 15-minute appointment. Our clinicians understand the emotional complexity — not just the symptoms.</p>
              <a href="/services" class="who-drawer-link">Learn more →</a>
            </div>
          </li>

          <li class="who-item" data-target="thyroid">
            <div class="who-trigger">
              <span class="who-dot"></span>
              <span class="who-name">Thyroid &amp; mood</span>
              <span class="who-arrow">→</span>
              <span class="who-chevron" aria-hidden="true"></span>
            </div>
            <div class="who-drawer">
              <p class="who-drawer-text">Thyroid disorders affect energy, sleep, cognition, and emotional regulation in ways that often get mistaken for depression or anxiety. We treat both — together.</p>
              <a href="/services" class="who-drawer-link">Learn more →</a>
            </div>
          </li>

        </ul>
        <div style="margin-top:32px">
          <a href="/services" class="btn-outline-ink">View all conditions</a>
        </div>
      </div>

      <div class="who-right">
        <div class="who-panel active" id="panel-pmdd">
          <div class="who-panel-img" style="background:#F2EDE8">
            <span class="who-panel-emoji">🌙</span>
            <span class="who-panel-tag">Premenstrual Dysphoric Disorder</span>
          </div>
          <h3>PMDD</h3>
          <p>The luteal phase shouldn't feel like a different life. Our clinicians understand PMDD at a neurological level — not as moodiness, but as a disorder that deserves real clinical attention and a real treatment plan.</p>
        </div>
        <div class="who-panel" id="panel-perimenopause">
          <div class="who-panel-img" style="background:#FFF5E8">
            <span class="who-panel-emoji">🍂</span>
            <span class="who-panel-tag">Perimenopause</span>
          </div>
          <h3>Perimenopause</h3>
          <p>The anxiety, rage, and grief that arrives before menopause is real — and undertreated. We work with women navigating hormonal transition with clinicians who understand what estrogen does to mood, cognition, and identity.</p>
        </div>
        <div class="who-panel" id="panel-postpartum">
          <div class="who-panel-img" style="background:#F0F8FF">
            <span class="who-panel-emoji">🌸</span>
            <span class="who-panel-tag">Postpartum</span>
          </div>
          <h3>Postpartum</h3>
          <p>Postpartum anxiety and depression are not character flaws. Our perinatal clinicians specialize in the emotional weight of the fourth trimester — and the months beyond it that no one talks about.</p>
        </div>
        <div class="who-panel" id="panel-fertility">
          <div class="who-panel-img" style="background:#F8F0FF">
            <span class="who-panel-emoji">🌿</span>
            <span class="who-panel-tag">Fertility Grief</span>
          </div>
          <h3>Fertility grief</h3>
          <p>Loss, IVF, miscarriage, and the in-between. Fertility grief is one of the most isolating emotional experiences a woman can face. We create space to process it — without minimizing it.</p>
        </div>
        <div class="who-panel" id="panel-pcos">
          <div class="who-panel-img" style="background:#F0FFF4">
            <span class="who-panel-emoji">⚡</span>
            <span class="who-panel-tag">PCOS</span>
          </div>
          <h3>PCOS</h3>
          <p>PCOS affects hormones, mood, body image, and identity in ways that are rarely addressed in a 15-minute appointment. Our clinicians understand the emotional complexity — not just the symptoms.</p>
        </div>
        <div class="who-panel" id="panel-thyroid">
          <div class="who-panel-img" style="background:#FFFBF0">
            <span class="who-panel-emoji">⚖️</span>
            <span class="who-panel-tag">Thyroid &amp; Mood</span>
          </div>
          <h3>Thyroid &amp; mood</h3>
          <p>Thyroid disorders affect energy, sleep, cognition, and emotional regulation in ways that often get mistaken for depression or anxiety. We treat both — together.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ───────────────────────────────── -->
<section class="how">
  <div class="container">
    <div class="how-head fade-up">
      <p class="eyebrow eyebrow-dark">How it works</p>
      <h2>From first contact<br>to ongoing care</h2>
      <p class="how-sub">You shouldn't have to figure out who to call or how to navigate your own care. We built a front door that actually works.</p>
    </div>
    <div class="how-steps">
      <div class="how-step fade-up">
        <div class="how-num">01</div>
        <h3>Book a 25-minute consultation</h3>
        <p>A video call with a licensed therapist to understand your needs, concerns, and goals — before you commit to anything.</p>
      </div>
      <div class="how-step fade-up">
        <div class="how-num">02</div>
        <h3>Get matched to your specialist</h3>
        <p>We pair you with a licensed clinician who has direct experience with your specific hormonal health concerns. Not a generalist.</p>
      </div>
      <div class="how-step fade-up">
        <div class="how-num">03</div>
        <h3>Begin coordinated care</h3>
        <p>Start therapy, access async support between sessions, and connect to our specialist network — all coordinated by your Mental Health Coordinator.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── CMBT ───────────────────────────────────────── -->
<section class="cmbt">
  <div class="container">
    <div class="cmbt-inner">
      <div class="cmbt-left fade-up">
        <p class="eyebrow eyebrow-gold">Our clinical modality</p>
        <h2>Core Messaging<br>Based Therapy™</h2>
        <p class="cmbt-desc">CMBT is our proprietary integrative therapy — designed to help clients uncover, explore, and reframe the internalized messages shaping their emotional and relational lives.</p>
        <div class="cmbt-pillars">
          <div class="cmbt-pillar">
            <div class="cmbt-pillar-dot"></div>
            <p><strong>Uncover</strong> — surface the messages that have shaped your relationship with your body and emotions</p>
          </div>
          <div class="cmbt-pillar">
            <div class="cmbt-pillar-dot"></div>
            <p><strong>Explore</strong> — understand where they came from and how they've organized your inner world</p>
          </div>
          <div class="cmbt-pillar">
            <div class="cmbt-pillar-dot"></div>
            <p><strong>Reframe</strong> — build a new relationship with yourself that isn't mediated by those messages</p>
          </div>
        </div>
        <a href="/cmbt" class="btn-gold">Learn about CMBT</a>
      </div>
      <div class="cmbt-right fade-up">
        <div class="cmbt-badge">Proprietary Modality</div>
        <p class="cmbt-name">Behold Your Wonder Center<br>Core Messaging Based Therapy™</p>
        <p class="cmbt-sub">An integrative approach drawing on multiple evidence-based frameworks — customized for women navigating hormonal mental health.</p>
        <div class="cmbt-methods">
          <span class="cmbt-method">CBT</span>
          <span class="cmbt-method">Psychodynamic</span>
          <span class="cmbt-method">EFT</span>
          <span class="cmbt-method">Humanistic</span>
          <span class="cmbt-method">Somatic</span>
          <span class="cmbt-method">Integrative</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ──────────────────────────────── -->
<section class="testimonials">
  <div class="container">
    <div class="t-head fade-up">
      <p class="eyebrow eyebrow-dark">Client experiences</p>
      <h2>Women who found<br>their way here</h2>
    </div>
    <div class="t-grid">
      <div class="t-card fade-up">
        <div class="t-stars">★★★★★</div>
        <p class="t-quote">"For the first time, my therapist understood that my cycle and my mental health were the same conversation."</p>
        <span class="t-condition">PMDD</span>
        <p class="t-author">— Client</p>
      </div>
      <div class="t-card fade-up">
        <div class="t-stars">★★★★★</div>
        <p class="t-quote">"I didn't have to explain myself from scratch. They already understood what perimenopause does to your mind."</p>
        <span class="t-condition">Perimenopause</span>
        <p class="t-author">— Client</p>
      </div>
      <div class="t-card fade-up">
        <div class="t-stars">★★★★★</div>
        <p class="t-quote">"The coordinator handled everything. I just had to show up. That alone changed everything for me."</p>
        <span class="t-condition">Postpartum</span>
        <p class="t-author">— Client</p>
      </div>
    </div>
  </div>
</section>

<!-- ── JOURNAL ───────────────────────────────────── -->
<section class="journal">
  <div class="container">
    <div class="journal-head">
      <div>
        <p class="eyebrow eyebrow-dark">From our journal</p>
        <h2>Understand what's<br>happening in your body</h2>
      </div>
      <a href="/journal" class="btn-outline-ink">View all articles</a>
    </div>
    <div class="j-grid">
      <a href="/journal/pmdd-brain" class="j-card">
        <div class="j-img" style="background:var(--green-lt)">🧠</div>
        <div class="j-body">
          <span class="j-tag">Hormonal health</span>
          <p class="j-title">What PMDD actually does to your brain — and why it's not a character flaw</p>
          <p class="j-excerpt">Understanding the luteal phase, estrogen withdrawal, and why your mood changes aren't a character flaw.</p>
          <span class="j-read">6 min read →</span>
        </div>
      </a>
      <a href="/journal/perimenopause-emotional-weight" class="j-card">
        <div class="j-img" style="background:#FFF5E8">🍂</div>
        <div class="j-body">
          <span class="j-tag">Mental wellness</span>
          <p class="j-title">The emotional weight of perimenopause nobody talks about</p>
          <p class="j-excerpt">Anxiety, rage, and grief that arrives before menopause — what it is and what actually helps.</p>
          <span class="j-read">8 min read →</span>
        </div>
      </a>
      <a href="/journal/fragmented-care" class="j-card">
        <div class="j-img" style="background:#F0F8FF">🔗</div>
        <div class="j-body">
          <span class="j-tag">Clinical insights</span>
          <p class="j-title">Why fragmented care fails women with hormonal conditions</p>
          <p class="j-excerpt">When your OBGYN and therapist never speak to each other, you pay the price. Here's a better model.</p>
          <span class="j-read">5 min read →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ── NEWSLETTER ─────────────────────────────────── -->
<section class="newsletter">
  <div class="container">
    <h2>The information you wished<br>your doctor gave you.</h2>
    <p class="newsletter-sub">Curated insights from leading professionals in women's mental health and hormonal care — delivered weekly.</p>
    <div class="newsletter-form">
      <input type="email" placeholder="Your email address" aria-label="Email address"/>
      <button type="submit" class="btn-dark">Subscribe</button>
    </div>
    <p class="newsletter-note">We never share your information. Unsubscribe any time.</p>
  </div>
</section>

</Layout>

<style>
/* ── HERO ─────────────────────────────────── */
.hero { position:relative; min-height:100vh; display:flex; align-items:center; overflow:hidden; }
.hero-poster { position:absolute; inset:0; z-index:0; background:#1a1208 url('https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=1600&q=80') center/cover no-repeat; }
.hero-video-wrap { position:absolute; inset:0; z-index:1; }
.hero-video-wrap video { width:100%; height:100%; object-fit:cover; object-position:center; }
.hero-overlay { position:absolute; inset:0; z-index:2; background:linear-gradient(105deg,rgba(10,8,6,.84) 0%,rgba(10,8,6,.6) 45%,rgba(10,8,6,.22) 100%); }
.hero-content { position:relative; z-index:3; padding:140px 0 100px; max-width:620px; }
.hero-eyebrow { display:inline-flex; align-items:center; gap:7px; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.18); backdrop-filter:blur(6px); border-radius:100px; padding:6px 14px; font-size:12px; font-weight:600; color:rgba(255,255,255,.85); margin-bottom:28px; }
.hero-dot { width:7px; height:7px; background:#7DD98A; border-radius:50%; flex-shrink:0; }
.hero h1 { font-family:'Fraunces',Georgia,serif; font-size:clamp(40px,5.5vw,72px); font-weight:300; line-height:1.08; color:#fff; margin-bottom:24px; }
.hero h1 em { font-style:italic; }
.hl { background:#F5B800; border-radius:6px; padding:1px 10px; color:#1E1E1E; }
.hero-sub { font-size:17px; color:rgba(255,255,255,.72); max-width:480px; margin-bottom:36px; line-height:1.75; font-weight:300; }
.hero-actions { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:28px; }
.btn-gold { background:#F5B800; color:#1E1E1E; font-size:14px; font-weight:600; padding:13px 26px; border-radius:100px; display:inline-block; transition:opacity .2s,transform .15s; }
.btn-gold:hover { opacity:.9; transform:translateY(-1px); }
.btn-ghost-white { background:transparent; border:1.5px solid rgba(255,255,255,.4); color:#fff; font-size:14px; font-weight:500; padding:12px 26px; border-radius:100px; display:inline-block; transition:border-color .2s; }
.btn-ghost-white:hover { border-color:#fff; }
.trust-row { display:flex; gap:10px; flex-wrap:wrap; }
.trust-chip { display:inline-flex; align-items:center; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.18); backdrop-filter:blur(6px); border-radius:100px; padding:7px 14px; font-size:13px; font-weight:500; color:rgba(255,255,255,.8); }
.hero-scroll { position:absolute; bottom:32px; left:50%; transform:translateX(-50%); z-index:3; display:flex; flex-direction:column; align-items:center; gap:6px; color:rgba(255,255,255,.4); font-size:10px; letter-spacing:.1em; text-transform:uppercase; }
.hero-scroll-line { width:1px; height:36px; background:linear-gradient(to bottom,rgba(255,255,255,.4),transparent); animation:scrollpulse 2s ease-in-out infinite; }
@keyframes scrollpulse { 0%,100%{opacity:.4} 50%{opacity:1} }

/* ── STATEMENT ────────────────────────────── */
.statement { background:#fff; padding:80px 0; text-align:center; }
.statement-text { font-family:'Fraunces',Georgia,serif; font-size:clamp(22px,3.2vw,40px); font-weight:300; line-height:1.35; color:#1E1E1E; max-width:800px; margin:0 auto 44px; }
.hl-ink { background:#F5B800; border-radius:5px; padding:1px 8px; }
.hl-green { background:#7DD98A; border-radius:5px; padding:1px 8px; }
.compliance-row { display:flex; gap:32px; justify-content:center; flex-wrap:wrap; align-items:center; }
.compliance-badge { display:flex; align-items:center; gap:10px; font-size:14px; font-weight:500; color:#5A5A5A; }
.compliance-icon { width:36px; height:36px; background:#E8F8EB; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; }

/* ── WHO IT'S FOR ─────────────────────────── */
.who { padding:96px 0; background:#F2EDE8; }
.who-inner { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; }
.who-list { margin-top:8px; }
.who-item { display:flex; flex-direction:column; border-bottom:1px solid rgba(30,30,30,.1); cursor:pointer; }
.who-item:first-child { border-top:1px solid rgba(30,30,30,.1); }
.who-trigger { display:flex; align-items:center; gap:10px; padding:16px 0; width:100%; }
.who-dot { width:8px; height:8px; border-radius:50%; background:#F5B800; flex-shrink:0; opacity:0; transition:opacity .15s; }
.who-item.active .who-dot { opacity:1; }
.who-name { font-family:'Fraunces',Georgia,serif; font-size:clamp(22px,2.5vw,32px); font-weight:300; color:#9A9A9A; transition:color .15s; line-height:1.1; }
.who-item.active .who-name, .who-item.open .who-name { color:#1E1E1E; }
.who-arrow { margin-left:auto; font-size:18px; opacity:0; transition:opacity .15s; flex-shrink:0; }
.who-item.active .who-arrow { opacity:1; }

/* Chevron — mobile only toggle indicator */
.who-chevron {
  display: none;
  margin-left: auto;
  width: 20px; height: 20px;
  flex-shrink: 0;
  position: relative;
}
.who-chevron::before,
.who-chevron::after {
  content: '';
  position: absolute;
  background: #1E1E1E;
  border-radius: 2px;
  transition: transform 0.25s ease;
}
.who-chevron::before { width: 10px; height: 1.5px; top: 50%; left: 2px; transform: translateY(-50%) rotate(45deg); }
.who-chevron::after  { width: 10px; height: 1.5px; top: 50%; right: 2px; transform: translateY(-50%) rotate(-45deg); }
.who-item.open .who-chevron::before { transform: translateY(-50%) rotate(-45deg); }
.who-item.open .who-chevron::after  { transform: translateY(-50%) rotate(45deg); }

/* Drawer — collapsed by default, opens on mobile */
.who-drawer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.38s ease, padding 0.3s ease;
  padding: 0 0 0 18px;
}
.who-item.open .who-drawer {
  max-height: 400px;
  padding: 4px 0 20px 18px;
}
.who-drawer-text { font-size:14px; color:#5A5A5A; line-height:1.75; margin-bottom:12px; }
.who-drawer-link { font-size:13px; font-weight:600; color:#1E1E1E; text-decoration:underline; text-underline-offset:3px; }

.btn-outline-ink { border:1.5px solid #1E1E1E; color:#1E1E1E; font-size:13px; font-weight:500; padding:12px 26px; border-radius:100px; display:inline-block; transition:background .2s,color .2s; }
.btn-outline-ink:hover { background:#1E1E1E; color:#fff; }
.who-right { position:sticky; top:100px; }
.who-panel { display:none; }
.who-panel.active { display:block; }
